fn iter_next() {
    let v = vec![4, 20, 16, 0, 3];

    let mut iterator = v.iter();

    assert_eq!(iterator.next(), Some(&4));
    assert_eq!(iterator.next(), Some(&20));
    assert_eq!(iterator.next(), Some(&16));
    assert_eq!(iterator.next(), Some(&0));
    assert_eq!(iterator.next(), Some(&3));
}

