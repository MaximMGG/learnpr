fn dump<T, U>(t: T)
where T: IntoIterator<Item=U>,
      U: Debug
{
    for u in t {
	println!("{:?}", u);
    }
}


fn reg_triangle(n: i32) -> i32 {
    let mut sum = 0;
    for i in 1..=n {
	sum += i
    }
    sum
}

fn renge_triangle(n: i32) -> i32 {
    (1..=n).fold(0, |sum, item| sum + item)
}

