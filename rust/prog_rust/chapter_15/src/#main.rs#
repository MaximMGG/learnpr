}

fn take_while_example() {
    let message = "to: jimb\r\nFrom: supergo <editor@oriely.com\r\n
\r\nDid you get any writing done today?\r\nWhen will you stop wasting time plotting fractals?";

    for header in message.lines().take_while(|l| !l.is_empty()) {
	println!("{header}");
    }

